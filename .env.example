# LINE Bot Configuration - Primary Account
LINE_CHANNEL_ACCESS_TOKEN=your_primary_access_token
LINE_CHANNEL_SECRET=your_primary_channel_secret
LINE_CHANNEL_ID=your_primary_channel_id

# LINE Bot Configuration - Secondary Account
LINE_CHANNEL_ACCESS_TOKEN_2=your_secondary_access_token
LINE_CHANNEL_SECRET_2=your_secondary_channel_secret
LINE_CHANNEL_ID_2=your_secondary_channel_id

# Google Sheets Configuration
GOOGLE_SHEET_ID=your_google_sheet_id
GOOGLE_SERVICE_ACCOUNT_KEY=credentials.json
GOOGLE_WORKSHEET_NAME=Bets

# Server Configuration
PORT=3001
NODE_ENV=development

# Webhook Configuration
WEBHOOK_URL=your_webhook_url

# LIFF Configuration
LIFF_ID=your_liff_id
LIFF_ID_OPEN_BETTING=your_liff_id_open_betting
LIFF_ID_RESULT_SUMMARY=your_liff_id_result_summary
LIFF_URL=https://liff.line.me
